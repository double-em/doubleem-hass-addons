{
  "name": "LLM AI Dashboard",
  "version": "0.1.0",
  "slug": "llm_ai_dashboard",
  "description": "AI Provider management, voice cloning, TTS, and AI memory for Home Assistant",
  "url": "https://github.com/double-em/llm-hass-app/tree/main/llm_ai_dashboard",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "hassio_api": true,
  "hassio_role": "default",
  "ports": {
    "8000/tcp": 8000
  },
  "map": [
    { "type": "share", "read_only": false, "path": "/data" }
  ],
  "options": {
    "default_provider": "minimax",
    "default_voice_speed": 1.0,
    "default_diffusion_steps": 32
  },
  "schema": {
    "default_provider": "str",
    "default_voice_speed": "num",
    "default_diffusion_steps": "int"
  },
  "image": "ghcr.io/double-em/llm-hass-app-{arch}"
}
